# ── Rudder configuration ────────────────────────────────────────
# Copy to `.env` and adjust. These are BOOTSTRAP values (where to reach
# things) — operational config lives in Git (jobs.yml + rudder.yml).
#
# `.env` is git-ignored. NEVER commit real tokens/passwords.

# Data mode:
#   mock = built-in demo data, no backend needed
#   live = bind the UI to the endpoints below (proxied server-side, no CORS)
DATA_SOURCE=mock

# Backend endpoints (used when DATA_SOURCE=live).
# Leave at the bundled service names to use `--profile bundled` containers,
# or point at your own external Prometheus / Loki / Vault.
PROMETHEUS_URL=http://prometheus:9090
LOKI_URL=http://loki:3100
VAULT_URL=http://vault:8200
CONTROL_PLANE_URL=http://control-plane:8090

# Vault / OpenBao.
# The bundled Vault (--profile bundled) uses encrypted file storage and is
# auto-unsealed by the vault-unseal sidecar: secrets are encrypted at rest and
# PERSIST across restarts. There is NO token to set here — the root token is
# generated at init and kept on a private volume (never in git). See SECURITY.md.
#
# Only set VAULT_TOKEN if you point Rudder at your OWN external Vault instead of
# the bundled one. Do NOT commit a real value.
# VAULT_TOKEN=

# Control plane (Phase 2)
RECONCILE_INTERVAL=15m

# Grafana (optional profile)
GRAFANA_PASSWORD=
